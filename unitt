status_matches() {
    local s1="$1"
    local s2="$2"

    if [ "$s1" -eq 0 ] && [ "$s2" -eq 0 ]; then
        return 0
    elif [ "$s1" -ne 0 ] && [ "$s2" -ne 0 ]; then
        return 0
    else
        return 1
    fi
}

# Escape regex metacharacters in a literal expected-string so it
# matches as text. `[] () ? ! |` are escaped outright. A `*` is
# escaped too — EXCEPT when it follows `.`, so the deliberate `.*`
# wildcard (used in expected strings to span variable text) keeps
# working while a bare `*` (e.g. in the grammar token `/*`) matches
# literally.
#
# !!!NOTE: `.*` stays a wildcard; everything else passed here is literal.
escape_expected() {
    local raw_pattern="$1"
    echo "$raw_pattern" | sed 's/\[/\\[/g; s/\]/\\]/g; s/(/\\(/g; s/)/\\)/g; s/?/\\?/g; s/!/\\!/g; s/|/\\|/g; s/\([^.]\)\*/\1\\*/g'
}
	
# Run $cmd with stdin from /dev/null, combining stdout+stderr, and capture both
# its output and exit status into the globals _rt_output / _rt_status.
# _rt_timed_out is set "true" (and _rt_status forced to 124, the timeout(1)
# convention) when a positive $2 timeout elapses and the command is killed.
#
# eval runs in a subshell of THIS shell so a test command that is itself a
# shell function (escape_expected, status_matches, preamble-defined helpers)
# still resolves. Globals are used rather than command substitution because the
# timeout path must `wait` in this shell — a subshell's background PID isn't
# waitable by the parent.
#
# Invariant: $2 (timeout) is a validated non-negative integer — every caller
# (startup for the env/flag baseline, run_test for the per-test arg) checks it,
# so `[ "$timeout" -le 0 ]` below is safe.
run_capture() {
    local cmd="$1" timeout="$2"
    _rt_timed_out="false"

    if [ "$timeout" -le 0 ]; then
        # No timeout: the historical fd trick, capturing output+status in one
        # subshell. stdin from /dev/null so a bare command that reads stdin when
        # it isn't a tty can't block on an inherited, never-EOF stdin; a command
        # that pipes its own stdin (`echo ... | cmd`) still gets its pipe.
        local full_output
        full_output=$( { eval "$cmd" </dev/null 2>&1; echo $? >&3; } 3>&1 | cat )
        _rt_status=${full_output##*$'\n'}
        _rt_output=${full_output%$'\n'*}
        _rt_output=${_rt_output%$'\n'}
        return 0
    fi

    # Timeout path: run the command in the background under a watchdog. `wait`
    # reaps it the instant it finishes, so a fast test pays no polling cost; a
    # wedged one is TERM'd (then KILL'd after a 1s grace) once the watchdog's
    # sleep elapses. A marker file disambiguates a real timeout from a command
    # that merely exited non-zero.
    local tmpd
    if ! tmpd=$(mktemp -d "${TMPDIR:-/tmp}/unitt_rc.XXXXXX") || [ -z "$tmpd" ]; then
        echo "run_capture: failed to create temp dir (check \$TMPDIR)" >&2
        exit 2
    fi
    # Track it so the EXIT reap can remove it if a signal interrupts us here.
    _rt_tmpd="$tmpd"
    ( eval "$cmd" </dev/null ) >"$tmpd/out" 2>&1 &
    local cmd_pid=$!
    (
        # Narrow race: if the command exits in the same instant this sleep
        # elapses, kill -0 may still see it and flag a (harmless) spurious
        # timeout. Acceptable for second-granularity timeouts.
        sleep "$timeout"
        if kill -0 "$cmd_pid" 2>/dev/null; then
            : > "$tmpd/timed_out"
            # Kill the whole tree, not just the eval subshell: a compound or
            # backgrounding command has children that would otherwise reparent
            # and leak. TERM first, then KILL after a 1s grace.
            _unitt_reap_tree "$cmd_pid" TERM
            sleep 1
            _unitt_reap_tree "$cmd_pid" KILL
        fi
    ) &
    local wd_pid=$!
    wait "$cmd_pid" 2>/dev/null
    _rt_status=$?
    kill "$wd_pid" 2>/dev/null
    wait "$wd_pid" 2>/dev/null
    if [ -e "$tmpd/timed_out" ]; then
        _rt_timed_out="true"
        _rt_status=124
    fi
    _rt_output=$(cat "$tmpd/out" 2>/dev/null)
    _rt_output=${_rt_output%$'\n'}
    rm -rf "$tmpd"
    _rt_tmpd=""
    return 0
}

# Helper function to run commands and check their output
run_test() {
    local cmd="$1"
    local expected_status="$2"
    local expected_regex="$3"
    local not_flag="${4:-false}"  # Default not_flag to false if not provided
    # Optional 5th arg: a per-test timeout (seconds) overriding the global
    # unitt_timeout for this call alone. Empty means "use the global".
    local test_timeout="${5:-$unitt_timeout}"
    if ! [[ "$test_timeout" =~ ^[0-9]+$ ]]; then
        echo "run_test: timeout must be a non-negative integer, got [$test_timeout]" >&2
        exit 2
    fi

    # --step: pause before running once the caller's line number in the
    # currently-sourced test unit is >= $step_line and the unit matches
    # $step_unit (when set). Reads keystrokes from /dev/tty so tests that
    # pipe stdin into the command under test aren't affected.
    local caller_line=${BASH_LINENO[0]}
    if [ -n "$step_line" ] \
       && { [ -z "$step_unit" ] || [ "$step_unit" = "$CURRENT_UNIT_ID" ]; } \
       && [ "$caller_line" -ge "$step_line" ]; then
        local caller_file="${BASH_SOURCE[1]##*/}"
        printf '\n--- step [%s:%s:%d] ---\n' "$CURRENT_UNIT_ID" "$caller_file" "$caller_line" >&2
        printf '  $ %s\n' "$cmd" >&2
        local not_suffix=""
        [ "$not_flag" = "true" ] && not_suffix=" (NOT)"
        printf '  Expected EXIT status:[%s] regex:[%s]%s\n' \
            "$expected_status" "$expected_regex" "$not_suffix" >&2
        local key="" target="" tunit="" tline="" tresolved="" tidx=""
        local done_prompt="false"
        while [ "$done_prompt" = "false" ]; do
			printf '[ENTER]=run, [c]ontinue/to (unit,)[l]ine, [s]kip, [q]uit ? ' >&2
            read -rsn1 key < /dev/tty
            printf '\n' >&2
            case "$key" in
                q|Q) echo "step: quit at [$CURRENT_UNIT_ID:$caller_file:$caller_line]" >&2; exit 0 ;;
                c|C) step_line=""; step_unit=""; done_prompt="true" ;;
                l|L)
                    print_unit_list
                    target=""
                    printf 'Continue to (unit,)line: ' >&2
                    read -r target < /dev/tty
                    # Empty input: re-display the main prompt so the user can pick again.
                    if [ -z "$target" ]; then
                        continue
                    fi
                    if [[ "$target" == *,* ]]; then
                        tunit="${target%%,*}"
                        tline="${target#*,}"
                        # Trailing comma with no line: "unit," means "jump to unit, start from the beginning".
                        [ -z "$tline" ] && tline="0"
                        tresolved=""
                        tidx=""
                        if [ -z "$tunit" ] || ! [[ "$tline" =~ ^[0-9]+$ ]]; then
                            echo "step: expected [unit,]line, got [$target] — staying at [$caller_line]" >&2
                        elif ! tresolved=$(unit_resolve "$tunit"); then
                            echo "step: unknown test unit [$tunit] — staying at [$caller_line]" >&2
                        else
                            tidx=$(unit_index "$tresolved")
                            if [ "${UNIT_DISABLED[$tidx]}" = "true" ]; then
                                echo "step: test unit [$tresolved] is disabled — staying at [$caller_line]" >&2
                            elif [ "$tidx" -lt "${CURRENT_UNIT_INDEX:-0}" ]; then
                                echo "step: test unit [$tresolved] has already completed — staying at [$caller_line]" >&2
                            else
                                step_unit="$tresolved"
                                step_line="$tline"
                            fi
                        fi
                    elif [[ "$target" =~ ^[0-9]+$ ]]; then
                        step_unit="$CURRENT_UNIT_ID"
                        step_line="$target"
                    else
                        echo "step: expected [unit,]line, got [$target] — staying at [$caller_line]" >&2
                    fi
                    done_prompt="true"
                    ;;
                s|S) echo "step: skipped [$CURRENT_UNIT_ID:$caller_file:$caller_line]" >&2; return 0 ;;
                *) done_prompt="true" ;;
            esac
        done
    fi

    #	local output=$(eval "$cmd" 2>&1)
	#	if [ "$not_flag" = "true" ]; then
	#	    # Check if expected is NOT in output
	#	    if [[ "$output" != *"$expected"* ]]; then
	#			echo "PASS: (NOT) $expected"
	#	    else
	#			echo
	#			echo "FAIL: $cmd"
	#			echo "Expected to NOT contain: $expected"
	#			echo "----"
	#			echo "$output"
	#			echo "----"
	#	    fi
	#	else
	#	    # Check if expected is in output
	#	    if [[ "$output" == *"$expected"* ]]; then
	#			echo "PASS: $expected"
	#	    else
	#			echo
	#			echo "FAIL: $cmd"
	#			echo "Expected to contain: $expected"
	#			echo "----"
	#			echo "$output"
	#			echo "----"
	#		fi
	#	fi

	# Grok
	# You're correct; both command substitution and eval in their basic forms do not 
	# allow for capturing both the output and the exit status of a command 
	# simultaneously in a straightforward way. However, there are workarounds to achieve this:
	# Using a Subshell for Capturing Both Output and Exit Status:
	# One way to capture both the output and the exit status is by using a subshell and command grouping:
	# Capture output and exit status
	#	output=$( { command_to_run 2>&1; echo $? >&3; } 3>&1 | cat )
	#	exit_status=${output##*$'\n'}
	#	output=${output%$'\n'*}
	# Now $output contains the command's output (including stderr),
	# and $exit_status contains the exit status
	# Here's the breakdown:
    #	- { command_to_run 2>&1; echo $? >&3; } is a command group where 
	#	  command_to_run is executed, its stdout and stderr are combined (2>&1), 
	#	  followed by echoing its exit status to file descriptor 3.
    #	- 3>&1 redirects file descriptor 3 to stdout before the group starts, allowing us 
	#	  to capture the exit status outside the group.
    #	- | cat ensures that the entire output (including the exit status) is passed to 
	#	  the command substitution.
    #	- We then split the output to separate the command output from the exit status:
    #		- exit_status=${output##*$'\n'} removes everything up to and 
	#		  including the last newline, leaving only the exit status.
	#		- output=${output%$'\n'*} removes the last line (which is the exit status) from the output.


    # Capture combined stdout+stderr and exit status (run_capture honors the
    # timeout: a wedged command is killed and surfaces as exit 124).
    run_capture "$cmd" "$test_timeout"
    local output="$_rt_output"
    local exit_status="$_rt_status"

    # A timed-out command is always a failure, regardless of the expected
    # status/regex — a hang must never be reported as a pass. Show whatever it
    # printed before the kill, and honor -c like any other failure.
    if [ "$_rt_timed_out" = "true" ]; then
        echo
        echo "# FAIL: [$cmd][TIMEOUT ${test_timeout}s], line no. [${BASH_LINENO[0]}]"
        echo "# Test exceeded the ${test_timeout}s per-test timeout and was killed."
        echo "#----"
        echo "$output" | sed 's/^/  /'
        echo "#----"
        echo
        fail_count=$((fail_count + 1))
        if [ "$continue_mode" != "true" ]; then
            echo "To be continued ..."
            echo
            exit 1
        fi
        return 0
    fi

	local ok="no"
	local status_ok="no"
	status_matches "$exit_status" "$expected_status" && status_ok="YES"
	if [ "$not_flag" = "true" ]; then
	    # Check if expected is NOT in output
		if ! [[ "$output" =~ $expected_regex ]]; then
			ok="YES"
			if status_matches "$exit_status" "$expected_status" && [ "$verbose_mode" != "true" ]; then
				echo "PASS: [$cmd][$exit_status] ! \"$expected_regex\", line no. [${BASH_LINENO[0]}]"
				pass_count=$((pass_count + 1))
				return 0
			fi 
		fi

		echo
		if [ "$ok" = "YES" ] && [ "$status_ok" = "YES" ]; then
			echo "# PASS: [$cmd][$exit_status], line no. [${BASH_LINENO[0]}]"
			pass_count=$((pass_count + 1))
		else
			echo "# FAIL: [$cmd][$exit_status], line no. [${BASH_LINENO[0]}]"
			fail_count=$((fail_count + 1))
		fi
		echo "# Expected EXIT status [$status_ok]: [$expected_status]"
		echo "# Expected to NOT contain [$ok]: \"$expected_regex\""
		echo "#----"
		echo "$output" | sed 's/^/  /'
		echo "#----"
		echo

		if [ "$ok" = "no" ] || ! status_matches "$exit_status" "$expected_status"; then
		  if [ "$continue_mode" != "true" ]; then
			echo "To be continued ..."
			echo
			exit 1
		  fi
		fi
	else
	    # Check if expected is in output
		if [[ "$output" =~ $expected_regex ]]; then
			ok="YES"
			if status_matches "$exit_status" "$expected_status" && [ "$verbose_mode" != "true" ]; then
				echo "PASS: [$cmd][$exit_status] \"$expected_regex\", line no. [${BASH_LINENO[0]}]"
				pass_count=$((pass_count + 1))
				return 0
			fi
		fi

		echo
		if [ "$ok" = "YES" ] && [ "$status_ok" = "YES" ]; then
			echo "# PASS: [$cmd][$exit_status], line no. [${BASH_LINENO[0]}]"
			pass_count=$((pass_count + 1))
		else
			echo "# FAIL: [$cmd][$exit_status], line no. [${BASH_LINENO[0]}]"
			fail_count=$((fail_count + 1))
		fi
		echo "# Expected EXIT status [$status_ok]: [$expected_status]"
		echo "# Expected to contain [$ok]: \"$expected_regex\""
		echo "#----"
		echo "$output" | sed 's/^/  /'
		echo "#----"
		echo

		if [ "$ok" = "no" ] || ! status_matches "$exit_status" "$expected_status"; then
		  if [ "$continue_mode" != "true" ]; then
			echo "To be continued ..."
			echo
			exit 1
		  fi
		fi
	fi
}

