#!/bin/bash

# This is a basic unit test script for the hash management script

usage() {
	echo
    echo "Usage: $(basename "$0") [-c|-v] [-u SEL] [-x SEL] [-t SECS] [--step [ID,]LINENO] [-l]"
    echo "Options:"
    echo "    -c, --continue              Continue processing tests even in the event of failure."
	echo "    -v, --verbose               Display all output regardless if pass or fail."
    echo "    -h, --help                  Display this help and exit"
    echo "    -u, --units SEL             Run only the selected test units. SEL is a comma-separated"
    echo "                                list of ids/names and/or numeric ranges (e.g. 0800-0835)."
    echo "    -x, --exclude SEL           Exclude the selected units (same SEL syntax). Applies on top"
    echo "                                of -u, or to all units when -u is omitted (e.g. -x 0316)."
    echo "    -t, --timeout SECS          Kill any single run_test that runs longer than SECS and fail it"
    echo "                                (0 disables; overrides UNITT_TIMEOUT). With -c the suite continues."
    echo "    --step [ID,]LINENO          Pause before each run_test call in test unit ID once its caller line is >= LINENO."
	echo "                                ID is required when more than one test unit is present after filtering."
	echo "                                Prompts: [Enter]=run, c=continue without stepping, l=continue to [unit,]line, s=skip, q=quit."
	echo "    -l, --list-units            List discovered test units (id / name and file) and exit."
	echo
	echo "Naming: test_YYY_XX-NAME.sh — YYY is the unit id used by --units. XX picks"
	echo "        unit_test/preamble_XX.sh (an all-zero XX means no preamble). Bare"
	echo "        test_NN-NAME.sh has no preamble."
	echo
	echo "Note: options -c and -v are mutually exclusive."
	echo
}

# Parse command line options
continue_mode="false"
verbose_mode="false"
list_units_mode="false"
units_filter=""
exclude_filter=""
timeout_flag=""
step_line=""
step_unit=""
pass_count=0
fail_count=0

# Generic cleanup: reap helper processes a test spawned (e.g. daemons) so a
# finished OR interrupted run doesn't orphan them. No knowledge of WHAT tests
# launch, so it stays project-agnostic.
#
# When unitt leads its own process group (the usual interactive `./unitt`
# case), anything ELSE in that group is something this run spawned — even a
# reparented orphan keeps the group id (helpers that don't `setsid` do), so a
# group-wide reap catches them. Under script/automation unitt may share its
# caller's group; group-killing would be unsafe, so we fall back to walking our
# own descendant tree (best effort — a reparented orphan escapes it; the
# project's own reap, e.g. a preamble, covers that case).
#
# Caveats nothing portable fixes: a SIGKILL of unitt can't be trapped, and a
# directed signal received while blocked in a foreground test command runs the
# trap only after that command returns.
# Signal a process and all its descendants, deepest first (so a parent doesn't
# reparent its children to init before they're reached). $2 is the signal name,
# default TERM. Used by the EXIT reap and by run_capture's timeout watchdog.
_unitt_reap_tree() {
    local root="$1" sig="${2:-TERM}" p
    for p in $(pgrep -P "$root" 2>/dev/null); do _unitt_reap_tree "$p" "$sig"; done
    [ "$root" = "$$" ] || kill "-$sig" "$root" 2>/dev/null
}
_unitt_reap() {
    local me="$$" pgid p
    # A timeout-path capture in flight leaves a temp dir behind on a signal;
    # run_capture clears _rt_tmpd on its normal path, so a non-empty value here
    # means we were interrupted mid-capture.
    [ -n "${_rt_tmpd:-}" ] && rm -rf "$_rt_tmpd" 2>/dev/null
    # Release the single-instance lock, but ONLY if we own it — a run that
    # LOST the acquire race still fires this EXIT trap, and must not delete
    # the winner's lock.
    [ -n "${_unitt_lockdir:-}" ] \
        && [ "$(cat "$_unitt_lockdir/pid" 2>/dev/null)" = "$$" ] \
        && rm -rf "$_unitt_lockdir" 2>/dev/null
    pgid=$(ps -o pgid= -p "$me" 2>/dev/null | tr -d ' ')
    if [ -n "$pgid" ] && [ "$pgid" = "$me" ]; then
        for p in $(ps -ax -o pid=,pgid= 2>/dev/null \
                   | awk -v g="$pgid" -v me="$me" '$2==g && $1!=me {print $1}'); do
            kill -TERM "$p" 2>/dev/null
        done
    else
        _unitt_reap_tree "$me"
    fi
}
trap '_unitt_reap' EXIT
trap 'exit 130' INT
trap 'exit 143' TERM HUP

# --- single-instance guard --------------------------------------------------
# Two concurrent ./unitt runs race on the shared test_Entropy_* store dirs and
# on the preamble's graveyard sweep (one run's rm -rf / pkill / socket-rm
# clobbers the other's in-flight state). Serialize with an atomic mkdir lock
# (macOS has no flock(1), so mkdir is the portable atomic-create primitive). A
# hard-killed run leaves a stale lock; reclaim it only when its pid is dead.
#
# NESTING: the suite self-tests by spawning a CHILD ./unitt. A child inherits
# the exported UNITT_LOCK_HELD marker from its lock-holding ancestor and must
# NOT re-acquire — the ancestor already serialized this run, so a child trying
# to lock would refuse ITSELF ("another run is active"). The lock guards only
# UNRELATED top-level invocations; a nested run rides on its parent's lock and
# leaves `_unitt_lockdir` unset, so it neither acquires nor releases (the
# release in _unitt_reap is gated on `_unitt_lockdir` being set). Isolating a
# nested child's stores/sockets from the parent's is the self-test's job, not
# the lock's.
if [ -z "${UNITT_LOCK_HELD:-}" ]; then
    _unitt_lockdir="${TMPDIR:-/tmp}/unitt.lock"
    if ! mkdir "$_unitt_lockdir" 2>/dev/null; then
        _owner=$(cat "$_unitt_lockdir/pid" 2>/dev/null)
        if [ -n "$_owner" ] && kill -0 "$_owner" 2>/dev/null; then
            echo "unitt: another run is active (pid $_owner) — refusing to avoid store/socket races." >&2
            echo "       (if that pid is dead, rm -rf $_unitt_lockdir)" >&2
            exit 1
        fi
        rm -rf "$_unitt_lockdir" 2>/dev/null             # stale lock from a killed run
        mkdir "$_unitt_lockdir" 2>/dev/null || { echo "unitt: cannot acquire $_unitt_lockdir" >&2; exit 1; }
    fi
    echo "$$" > "$_unitt_lockdir/pid"
    export UNITT_LOCK_HELD="$$"
fi

parse_step_value() {
    # Parse the value of --step=... into the globals step_unit/step_line.
    # Echoes errors and returns non-zero on bad input.
    local raw="$1"
    if [[ "$raw" == *,* ]]; then
        step_unit="${raw%%,*}"
        step_line="${raw#*,}"
        if [ -z "$step_unit" ] || [ -z "$step_line" ]; then
            echo "step: expected ID,LINE, got [$raw]" >&2
            return 1
        fi
    else
        step_unit=""
        step_line="$raw"
    fi
    if ! [[ "$step_line" =~ ^[0-9]+$ ]]; then
        echo "step: expected numeric line number, got [$step_line]" >&2
        return 1
    fi
    return 0
}

need_value() {
    # Helper for options that take a separate-argument value. Echoes the value,
    # or prints an error and returns non-zero when the next positional is
    # missing.
    local opt="$1" hint="$2" remaining="$3" next="$4"
    if [ "$remaining" -lt 2 ]; then
        echo "${opt#--}: missing value (use $hint)" >&2
        return 1
    fi
    printf '%s\n' "$next"
    return 0
}

while [ $# -gt 0 ]; do
    arg="$1"
    case "$arg" in
        -c|--continue)
            continue_mode="true"
            shift
            ;;
        -v|--verbose)
            verbose_mode="true"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -l|--list-units)
            list_units_mode="true"
            shift
            ;;
        -u|--units)
            if ! val=$(need_value "--units" "--units ID[,ID...]" "$#" "${2-}"); then
                usage; exit 2
            fi
            units_filter="$val"
            if [ -z "$units_filter" ]; then
                echo "units: missing value (use --units ID[,ID...])" >&2
                usage; exit 2
            fi
            shift 2
            ;;
        -x|--exclude)
            if ! val=$(need_value "--exclude" "--exclude ID[,ID...]" "$#" "${2-}"); then
                usage; exit 2
            fi
            exclude_filter="$val"
            if [ -z "$exclude_filter" ]; then
                echo "exclude: missing value (use --exclude ID[,ID...])" >&2
                usage; exit 2
            fi
            shift 2
            ;;
        -t|--timeout)
            if ! val=$(need_value "--timeout" "--timeout SECS" "$#" "${2-}"); then
                usage; exit 2
            fi
            timeout_flag="$val"
            shift 2
            ;;
        --step)
            if ! val=$(need_value "--step" "--step [ID,]LINENO" "$#" "${2-}"); then
                usage; exit 2
            fi
            if ! parse_step_value "$val"; then
                usage; exit 2
            fi
            shift 2
            ;;
        --)
            shift
            break
            ;;
        --*)
            echo "Invalid option: $arg" >&2
            usage; exit 2
            ;;
        -[a-zA-Z]*)
            # Any short-form starting with -X that didn't match an explicit
            # case above is an unknown short flag (or unsupported cluster).
            echo "${0##*/}: illegal option -- ${arg#-}" >&2
            usage; exit 2
            ;;
        *)
            echo "Unexpected argument: $arg" >&2
            usage; exit 2
            ;;
    esac
done

# Per-test timeout in seconds. The baseline is seeded from UNITT_TIMEOUT
# (0/unset disables it); the --timeout flag, when given, overrides the env var.
# The baseline is immutable; unitt_timeout is the live value run_test reads and
# is reset to the baseline before each unit, so a preamble may set it to scope a
# timeout to its unit without leaking into later units.
unitt_timeout_baseline=${UNITT_TIMEOUT:-0}
# A bad env var isn't a CLI misuse, so it errors without printing usage; a bad
# --timeout flag does print usage. Both exit 2.
if [ -n "${UNITT_TIMEOUT:-}" ] && ! [[ "$UNITT_TIMEOUT" =~ ^[0-9]+$ ]]; then
    echo "UNITT_TIMEOUT: expected a non-negative integer (seconds), got [$UNITT_TIMEOUT]" >&2
    exit 2
fi
if [ -n "$timeout_flag" ]; then
    if ! [[ "$timeout_flag" =~ ^[0-9]+$ ]]; then
        echo "timeout: expected a non-negative integer (seconds), got [$timeout_flag]" >&2
        usage; exit 2
    fi
    unitt_timeout_baseline="$timeout_flag"
fi
unitt_timeout="$unitt_timeout_baseline"

