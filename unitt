#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# Helpers used by the step gate and discovery loop.
#
# A numbered unit (test_NN-name.sh) is addressable by either its number or its
# name; an unnumbered unit (test_core.sh) is addressable by its name only.
# unit_resolve takes user input and prints the canonical primary ID.
unit_resolve() {
    local target="$1"
    local i
    for i in "${!UNIT_IDS[@]}"; do
        if [ "${UNIT_IDS[$i]}" = "$target" ] || [ "${UNIT_NAMES[$i]}" = "$target" ]; then
            printf '%s\n' "${UNIT_IDS[$i]}"
            return 0
        fi
    done
    return 1
}

unit_exists() {
    unit_resolve "$1" >/dev/null
}

unit_index() {
    local target="$1"
    local i
    for i in "${!UNIT_IDS[@]}"; do
        if [ "${UNIT_IDS[$i]}" = "$target" ]; then
            printf '%s\n' "$i"
            return 0
        fi
    done
    return 1
}

# Expand one --units/--exclude token into canonical unit IDs (space-separated,
# on stdout). A token is an id, a name, or a numeric range `LO-HI` (inclusive,
# zero-padding tolerated). A range selects every numeric-id unit in [LO,HI] and
# silently skips disabled ones; an explicitly-named disabled unit is an error.
# `$2` is "units"|"exclude" for messages. Returns non-zero on a bad token.
expand_unit_token() {
    local tok="$1" flag="$2"
    if [[ "$tok" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        local lo="${BASH_REMATCH[1]}" hi="${BASH_REMATCH[2]}"
        if [ "$((10#$lo))" -gt "$((10#$hi))" ]; then
            echo "$flag: inverted range [$tok]" >&2; return 1
        fi
        local i uid matched=""
        for i in "${!UNIT_IDS[@]}"; do
            uid="${UNIT_IDS[$i]}"
            [[ "$uid" =~ ^[0-9]+$ ]] || continue          # only numeric ids range
            [ "${UNIT_DISABLED[$i]}" = "true" ] && continue
            if [ "$((10#$uid))" -ge "$((10#$lo))" ] && [ "$((10#$uid))" -le "$((10#$hi))" ]; then
                matched="$matched $uid"
            fi
        done
        if [ -z "$matched" ]; then
            echo "$flag: range [$tok] matched no enabled units" >&2; return 1
        fi
        printf '%s\n' "$matched"
        return 0
    fi
    local resolved ridx
    if resolved=$(unit_resolve "$tok"); then
        ridx=$(unit_index "$resolved")
        if [ "${UNIT_DISABLED[$ridx]}" = "true" ]; then
            echo "$flag: test unit [$tok] is disabled" >&2; return 1
        fi
        printf '%s\n' "$resolved"
        return 0
    fi
    echo "$flag: unknown test unit [$tok]" >&2
    return 1
}

# Expand a comma-separated SEL list into a de-duplicated, space-separated set of
# canonical unit IDs on stdout. Returns non-zero (with a message) on any bad
# entry. `$2` is "units"|"exclude" for messages.
expand_unit_list() {
    local list="$1" flag="$2" out="" tok id ids
    local -a parts
    IFS=',' read -ra parts <<< "$list"
    for tok in "${parts[@]}"; do
        if [ -z "$tok" ]; then
            echo "$flag: empty entry in [$list]" >&2; return 1
        fi
        if ! ids=$(expand_unit_token "$tok" "$flag"); then
            return 1
        fi
        for id in $ids; do
            case " $out " in *" $id "*) ;; *) out="$out $id" ;; esac
        done
    done
    printf '%s\n' "$out"
}

# Always lists every discovered unit. During a step pause, units that have
# already been sourced are marked "done" — the table still shows them for
# context, but the `l` handler refuses to jump there. Units whose filename
# starts with `_` are listed with a "(disabled)" marker; they're discovered
# for visibility but never sourced and cannot be selected.
print_unit_list() {
    local in_step="false"
    [ -n "${CURRENT_UNIT_ID:-}" ] && in_step="true"
    if [ "$in_step" = "true" ]; then
        printf 'Available units (current: %s):\n' "$CURRENT_UNIT_ID" >&2
    else
        printf 'Available units:\n' >&2
    fi
    local i status label start_idx
    start_idx="${CURRENT_UNIT_INDEX:-0}"
    for i in "${!UNIT_IDS[@]}"; do
        status=""
        if [ "${UNIT_DISABLED[$i]:-false}" = "true" ]; then
            status="  * disabled"
        elif [ "$in_step" = "true" ]; then
            if [ "${UNIT_IDS[$i]}" = "$CURRENT_UNIT_ID" ]; then
                status="<-- current"
            elif [ "$i" -lt "$start_idx" ]; then
                status="  ■ (done)"
            fi
        fi
        if [ "${UNIT_IDS[$i]}" = "${UNIT_NAMES[$i]}" ]; then
            label="[${UNIT_IDS[$i]}]"
        else
            label="[${UNIT_IDS[$i]}]-[${UNIT_NAMES[$i]}]"
        fi
        if [ -n "$status" ]; then
            printf '  unit:%-18s unit_test/%-26s %s\n' "$label" "[${UNIT_FILES[$i]##*/}]" "$status" >&2
        else
            printf '  unit:%-18s unit_test/%s\n' "$label" "[${UNIT_FILES[$i]##*/}]" >&2
        fi
    done
}

# Discover unit_test/test_*.sh and source them in order. Numbered files
# (test_NN-...) run first by numeric value, then unnumbered files
# alphabetically. UNIT_TEST_CORE overrides discovery for single-file
# regression rigs (see verbose-mode tests in test_core.sh).
UNIT_IDS=()
UNIT_NAMES=()
UNIT_FILES=()
UNIT_DISABLED=()
UNIT_PREAMBLE_TAGS=()

if [ -n "${UNIT_TEST_CORE:-}" ]; then
    UNIT_IDS=("core")
    UNIT_NAMES=("core")
    UNIT_FILES=("$UNIT_TEST_CORE")
    UNIT_DISABLED=("false")
    UNIT_PREAMBLE_TAGS=("00")
else
    _sortkeys=()
    # Discovery picks up both enabled (`test_*.sh`) and disabled
    # (`_test_*.sh`) units. Disabled units appear in --list-units output but
    # are never sourced and cannot be selected by --units / --step.
    #
    # Naming patterns recognised:
    #   test_YYY_XX-NAME.sh — YYY is the unit id used by --units / --step.
    #                         XX is the preamble tag (sourced from
    #                         unit_test/preamble_XX.sh; an all-zero XX means
    #                         none — "0", "00", "000" all skip the source).
    #   test_NN-NAME.sh     — no preamble sourced; NN is the unit id.
    #   test_NAME.sh        — non-numeric id; no preamble; sorted after numerics.
    for f in unit_test/test_*.sh unit_test/_test_*.sh; do
        [ -e "$f" ] || continue
        bn_full="${f##*/}"
        if [[ "$bn_full" == _test_* ]]; then
            disabled="true"
            bn="${bn_full%.sh}"; bn="${bn#_test_}"
        else
            disabled="false"
            bn="${bn_full%.sh}"; bn="${bn#test_}"
        fi
        preamble_tag="00"
        if [[ "$bn" =~ ^([0-9]+)_([0-9a-zA-Z]+)(-(.+))?$ ]]; then
            id="${BASH_REMATCH[1]}"
            preamble_tag="${BASH_REMATCH[2]}"
            name="${BASH_REMATCH[4]}"
            [ -z "$name" ] && name="$id"
            # Sort key uses $((10#...)) — bash 64-bit signed arithmetic. 18
            # digits is the largest length that always fits regardless of
            # value; non-digit preamble tags would also blow up there.
            # Catch both at startup so the failure is named, not a cryptic
            # "value too great for base" from inside the discovery loop.
            if ! [[ "$preamble_tag" =~ ^[0-9]+$ ]]; then
                echo "ERROR: [$bn_full]: preamble-form tag [$preamble_tag] must be all-digit" >&2
                exit 2
            fi
            if [ "${#id}" -gt 18 ] || [ "${#preamble_tag}" -gt 18 ]; then
                echo "ERROR: [$bn_full]: id or preamble tag exceeds 18 digits (sort key would overflow)" >&2
                exit 2
            fi
            sk=$(printf '0_%010d_%010d' "$((10#$id))" "$((10#$preamble_tag))")
        elif [[ "$bn" =~ ^([0-9]+)(-(.+))?$ ]]; then
            id="${BASH_REMATCH[1]}"
            name="${BASH_REMATCH[3]}"
            [ -z "$name" ] && name="$id"
            if [ "${#id}" -gt 18 ]; then
                echo "ERROR: [$bn_full]: id exceeds 18 digits (sort key would overflow)" >&2
                exit 2
            fi
            sk=$(printf '0_%010d_0000000000' "$((10#$id))")
        else
            id="$bn"
            name="$bn"
            sk="1_$bn"
        fi
        UNIT_IDS+=("$id"); UNIT_NAMES+=("$name"); UNIT_FILES+=("$f")
        UNIT_DISABLED+=("$disabled"); UNIT_PREAMBLE_TAGS+=("$preamble_tag")
        _sortkeys+=("$sk")
    done

    if [ "${#UNIT_IDS[@]}" -eq 0 ]; then
        echo "ERROR: no test units found in unit_test/test_*.sh" >&2
        exit 2
    fi

    indices=( $(for i in "${!_sortkeys[@]}"; do
                    printf '%s\t%s\n' "${_sortkeys[$i]}" "$i"
                done | sort | awk -F'\t' '{print $2}') )
    sorted_ids=()
    sorted_names=()
    sorted_files=()
    sorted_disabled=()
    sorted_preamble_tags=()
    for i in "${indices[@]}"; do
        sorted_ids+=("${UNIT_IDS[$i]}")
        sorted_names+=("${UNIT_NAMES[$i]}")
        sorted_files+=("${UNIT_FILES[$i]}")
        sorted_disabled+=("${UNIT_DISABLED[$i]}")
        sorted_preamble_tags+=("${UNIT_PREAMBLE_TAGS[$i]}")
    done
    UNIT_IDS=("${sorted_ids[@]}")
    UNIT_NAMES=("${sorted_names[@]}")
    UNIT_FILES=("${sorted_files[@]}")
    UNIT_DISABLED=("${sorted_disabled[@]}")
    UNIT_PREAMBLE_TAGS=("${sorted_preamble_tags[@]}")

    # Catch collisions between any pair of (id, name) across enabled units.
    # Disabled (`_test_*.sh`) units are skipped so a disabled leftover can
    # share an id with its active replacement without tripping the check.
    seen=""
    for i in "${!UNIT_IDS[@]}"; do
        [ "${UNIT_DISABLED[$i]}" = "true" ] && continue
        id="${UNIT_IDS[$i]}"
        name="${UNIT_NAMES[$i]}"
        case " $seen " in *" $id "*)
            echo "ERROR: duplicate test unit identifier [$id]" >&2
            exit 2 ;;
        esac
        seen="$seen $id"
        if [ "$name" != "$id" ]; then
            case " $seen " in *" $name "*)
                echo "ERROR: duplicate test unit identifier [$name]" >&2
                exit 2 ;;
            esac
            seen="$seen $name"
        fi
    done
fi

# Apply --units / --exclude selection. SEL is a comma-separated list of
# ids/names and/or numeric ranges (LO-HI); see expand_unit_list. The base set
# is the -u selection, or all enabled units when -u is omitted; -x is then
# subtracted. Discovery order is preserved so behaviour is independent of how
# the user listed them.
if [ -n "$units_filter" ] || [ -n "$exclude_filter" ]; then
    # Base set.
    if [ -n "$units_filter" ]; then
        if ! selected_ids=$(expand_unit_list "$units_filter" "units"); then
            usage; exit 2
        fi
    else
        selected_ids=""
        for i in "${!UNIT_IDS[@]}"; do
            [ "${UNIT_DISABLED[$i]}" = "true" ] && continue
            selected_ids="$selected_ids ${UNIT_IDS[$i]}"
        done
    fi

    # Subtract the exclusion set.
    excluded_ids=""
    if [ -n "$exclude_filter" ]; then
        if ! excluded_ids=$(expand_unit_list "$exclude_filter" "exclude"); then
            usage; exit 2
        fi
    fi
    final_ids=""
    for id in $selected_ids; do
        case " $excluded_ids " in
            *" $id "*) ;;                              # excluded — drop
            *) final_ids="$final_ids $id" ;;
        esac
    done
    if [ -z "$final_ids" ]; then
        echo "units: selection is empty after exclusions" >&2
        exit 2
    fi

    new_ids=(); new_names=(); new_files=(); new_disabled=(); new_preamble_tags=()
    for i in "${!UNIT_IDS[@]}"; do
        case " $final_ids " in *" ${UNIT_IDS[$i]} "*)
            new_ids+=("${UNIT_IDS[$i]}")
            new_names+=("${UNIT_NAMES[$i]}")
            new_files+=("${UNIT_FILES[$i]}")
            new_disabled+=("${UNIT_DISABLED[$i]}")
            new_preamble_tags+=("${UNIT_PREAMBLE_TAGS[$i]}")
            ;;
        esac
    done
    UNIT_IDS=("${new_ids[@]}")
    UNIT_NAMES=("${new_names[@]}")
    UNIT_FILES=("${new_files[@]}")
    UNIT_DISABLED=("${new_disabled[@]}")
    UNIT_PREAMBLE_TAGS=("${new_preamble_tags[@]}")
fi

if [ "$list_units_mode" = "true" ]; then
    print_unit_list
    exit 0
fi

# Count enabled units so a bare --step LINE works whenever exactly one
# enabled unit will run, even if the discovery list contains disabled ones.
enabled_count=0
sole_enabled_id=""
for _i in "${!UNIT_IDS[@]}"; do
    if [ "${UNIT_DISABLED[$_i]}" = "false" ]; then
        enabled_count=$((enabled_count + 1))
        sole_enabled_id="${UNIT_IDS[$_i]}"
    fi
done

# Validate --step now that we know which units will run.
if [ -n "$step_line" ]; then
    if [ -z "$step_unit" ]; then
        if [ "$enabled_count" -ne 1 ]; then
            echo "step: expected ID,LINE (multiple test units present)" >&2
            usage
            exit 2
        fi
        step_unit="$sole_enabled_id"
    else
        if resolved=$(unit_resolve "$step_unit"); then
            ridx=$(unit_index "$resolved")
            if [ "${UNIT_DISABLED[$ridx]}" = "true" ]; then
                echo "step: test unit [$step_unit] is disabled" >&2
                usage
                exit 2
            fi
            step_unit="$resolved"
        else
            echo "step: unknown test unit [$step_unit]" >&2
            usage
            exit 2
        fi
    fi
fi

for _i in "${!UNIT_IDS[@]}"; do
    if [ "${UNIT_DISABLED[$_i]}" = "true" ]; then
        continue
    fi
    CURRENT_UNIT_ID="${UNIT_IDS[$_i]}"
    CURRENT_UNIT_NAME="${UNIT_NAMES[$_i]}"
    CURRENT_UNIT_INDEX="$_i"
    CURRENT_UNIT_PREAMBLE_TAG="${UNIT_PREAMBLE_TAGS[$_i]}"
    # Reset to the baseline so a preamble's timeout override is scoped to its
    # own unit and doesn't leak into the next.
    unitt_timeout="$unitt_timeout_baseline"
    if [ "$((10#$CURRENT_UNIT_PREAMBLE_TAG))" -ne 0 ]; then
        _pre="unit_test/preamble_${CURRENT_UNIT_PREAMBLE_TAG}.sh"
        if [ -f "$_pre" ]; then
            source "$_pre"
        else
            echo "ERROR: preamble [$_pre] not found for unit [$CURRENT_UNIT_ID]" >&2
            exit 2
        fi
    fi
    source "${UNIT_FILES[$_i]}"
done

#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

echo
echo "Done."
echo "SUMMARY: $pass_count passed, $fail_count failed"
echo
[ "$fail_count" -gt 0 ] && exit 1
exit 0



